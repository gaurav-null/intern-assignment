    {
      "name": "Todos",
      "item": [
        {
          "name": "Create Todo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Study Docker\",\n  \"description\": \"Learn containerization\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/v2/todos",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "v2", "todos"]
            }
          }
        },
        {
          "name": "Get All Todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/api/v2/todos",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "v2", "todos"]
            }
          }
        },
        {
          "name": "Update Todo",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Study Docker\",\n  \"description\": \"Learn containerization and compose\",\n  \"completed\": true\n}"
