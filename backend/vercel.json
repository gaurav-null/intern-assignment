{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "PORT": "3000",
    "DB_HOST": "@db_host",
    "DB_PORT": "@db_port",
    "DB_USER": "@db_user",
    "DB_NAME": "@db_name",
    "DB_PASSWORD": "@db_password",
    "JWT_SECRET": "@jwt_secret",
    "CLIENT_URL": "@client_url"
  }
}